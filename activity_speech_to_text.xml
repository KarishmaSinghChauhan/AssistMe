<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/micImageButtonId"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#B7FCEA4B"
    tools:context=".SpeechToTextActivity">

    <TextView
        android:id="@+id/textView2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#D3FF9800"
        android:gravity="center"
        android:text="Speech to Text"
        android:textColor="#0A0A0A"
        android:textSize="24sp" />

    <EditText
        android:id="@+id/editText2Id"
        android:layout_width="380dp"
        android:layout_height="236dp"
        android:layout_below="@+id/textView2"
        android:layout_alignParentEnd="true"
        android:layout_marginStart="8dp"
        android:layout_marginTop="0dp"
        android:layout_marginEnd="9dp"
        android:ems="10"
        android:gravity="start|top"
        android:hint="The translated speech text will appear here.."
        android:inputType="textMultiLine"
        android:onClick="enable"
        android:textColor="#9C27B0" />

    <ImageButton
        android:id="@+id/speakImageButtonId"
        android:layout_width="71dp"
        android:layout_height="66dp"
        android:layout_below="@+id/radioGroupId"
        android:layout_alignParentEnd="true"
        android:layout_marginStart="8dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="142dp"
        android:src="@drawable/mic_image6" />

    <Button
        android:id="@+id/saveButton2Id"
        android:layout_width="76dp"
        android:layout_height="35dp"
        android:layout_below="@+id/editText2Id"
        android:layout_alignParentEnd="true"
        android:layout_marginStart="8dp"
        android:layout_marginTop="19dp"
        android:layout_marginEnd="139dp"
        android:background="#03A9F4"
        android:enabled="true"
        android:onClick="save"
        android:text="save" />

    <RadioGroup
        android:id="@+id/radioGroupId"
        android:layout_width="155dp"
        android:layout_height="135dp"
        android:layout_below="@+id/saveButton2Id"
        android:layout_alignParentEnd="true"
        android:layout_marginStart="8dp"
        android:layout_marginTop="15dp"
        android:layout_marginEnd="64dp">

        <RadioButton
            android:id="@+id/radioButton9"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:checked="true"
            android:text="English" />

        <RadioButton
            android:id="@+id/radioButton7"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="French" />

        <RadioButton
            android:id="@+id/radioButton8"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="German" />

        <RadioButton
            android:id="@+id/radioButton10"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Italian" />
    </RadioGroup>

</RelativeLayout>